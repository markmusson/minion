{
  "id": "minion",
  "name": "Minion Sandbox Instance",
  "gateway": {
    "port": 18789,
    "bind": "0.0.0.0"
  },
  "models": {
    "default": "anthropic/claude-sonnet-4-5",
    "providers": {
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}",
        "models": ["claude-opus-4-5", "claude-sonnet-4-5", "claude-haiku-4-5"]
      },
      "openai": {
        "apiKey": "${OPENAI_API_KEY}",
        "models": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo"]
      }
    }
  },
  "channels": {
    "webhook": {
      "enabled": true,
      "port": 18790
    }
  },
  "agents": {
    "defaults": {
      "profile": "messaging",
      "model": "anthropic/claude-sonnet-4-5"
    }
  },
  "storage": {
    "type": "sqlite",
    "path": "/root/.openclaw/minion.db"
  }
}
